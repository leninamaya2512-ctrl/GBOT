<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GBOT | Terminal de la República</title>
    <style>
        :root {
            --bg-color: #050c1c;
            --container-bg: #0a192f;
            --accent-color: #00e676;
            --text-color: #e6f1ff;
            --bot-msg-bg: #112240;
            --user-msg-bg: #233554;
        }

        body { 
            font-family: 'Courier New', Courier, monospace; 
            background-color: var(--bg-color); 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            height: 100vh; 
            margin: 0; 
            color: var(--text-color);
        }

        #chat-container { 
            width: 90%; 
            max-width: 450px; 
            height: 80vh; 
            background: var(--container-bg); 
            border-radius: 12px; 
            display: flex; 
            flex-direction: column; 
            overflow: hidden; 
            border: 2px solid var(--accent-color); 
            box-shadow: 0 0 30px rgba(0, 230, 118, 0.15); 
        }

        #header { 
            background: var(--accent-color); 
            color: var(--bg-color); 
            padding: 15px; 
            text-align: center; 
            font-weight: bold; 
            font-size: 1.1em;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        #chat-box { 
            flex: 1; 
            padding: 20px; 
            overflow-y: auto; 
            display: flex; 
            flex-direction: column; 
            gap: 15px; 
            background-image: radial-gradient(rgba(100, 255, 218, 0.05) 1px, transparent 1px); 
            background-size: 30px 30px; 
        }

        .message { 
            padding: 12px 16px; 
            border-radius: 8px; 
            max-width: 80%; 
            font-size: 0.95em; 
            line-height: 1.5;
            position: relative;
        }

        .user { 
            background: var(--user-msg-bg); 
            align-self: flex-end; 
            border-bottom-right-radius: 2px;
            border-right: 3px solid var(--accent-color);
        }

        .bot { 
            background: var(--bot-msg-bg); 
            align-self: flex-start; 
            border-bottom-left-radius: 2px;
            border-left: 3px solid var(--accent-color);
            color: #64ffda;
        }

        #input-area { 
            display: flex; 
            padding: 20px; 
            background: var(--container-bg); 
            border-top: 1px solid #233554; 
        }

        input { 
            flex: 1; 
            padding: 12px; 
            border: 1px solid var(--user-msg-bg); 
            border-radius: 5px; 
            outline: none; 
            background: #020c1b; 
            color: var(--accent-color); 
            font-family: 'Courier New', monospace; 
        }

        button { 
            background: var(--accent-color); 
            border: none; 
            padding: 10px 20px; 
            margin-left: 10px; 
            border-radius: 5px; 
            cursor: pointer; 
            font-weight: bold; 
            color: var(--bg-color);
            transition: 0.3s;
        }

        button:hover { 
            background: #64ffda;
            transform: scale(1.05);
        }

        /* Scrollbar personalizada */
        #chat-box::-webkit-scrollbar { width: 5px; }
        #chat-box::-webkit-scrollbar-thumb { background: var(--user-msg-bg); border-radius: 10px; }
    </style>
</head>
